   283	describe('garminDedupKey', () => {
   284	  it('is deterministic and value-sensitive (sha256 hex)', () => {
   285	    const at = new Date('2026-05-20T00:00:00.000Z');
   286	    const a = garminDedupKey({
   287	      userId: 'garmin-99',
   288	      metric: WearableMetricType.STEPS,
   289	      startAt: at,
   290	      value: 8421,
   291	    });
   292	    const b = garminDedupKey({
   293	      userId: 'garmin-99',
   294	      metric: WearableMetricType.STEPS,
   295	      startAt: at,
   296	      value: 8421,
   297	    });
   298	    const c = garminDedupKey({
   299	      userId: 'garmin-99',
   300	      metric: WearableMetricType.STEPS,
   301	      startAt: at,
   302	      value: 8422, // different value
   303	    });
   304	    expect(a).toMatch(/^[0-9a-f]{64}$/);
   305	    expect(a).toBe(b);
   306	    expect(a).not.toBe(c);
   307	  });
   308	
   309	  it('differs from the foundation row dedup_key (value is folded in)', () => {
   310	    const at = new Date('2026-05-20T00:00:00.000Z');
   311	    const connectorKey = garminDedupKey({
   312	      userId: USER,
   313	      metric: WearableMetricType.STEPS,
   314	      startAt: at,
   315	      value: 8421,
   316	    });
   317	    const rowKey = computeDedupKey({
   318	      userId: USER,
   319	      provider: WearableProvider.GARMIN,
   320	      metric: WearableMetricType.STEPS,
   321	      startAt: at,
   322	      endAt: at,
   323	    });
   324	    expect(connectorKey).not.toBe(rowKey);
   325	  });
   326	});
