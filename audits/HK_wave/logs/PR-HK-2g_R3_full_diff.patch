+      c.verifyWebhook({
+        rawBody,
+        headers: { 'polar-webhook-signature': signature },
+      }),
+    ).toBe(true);
+  });
+
+  it('rejects a bad signature', () => {
+    const { client } = makeHttp();
+    expect(
+      new PolarConnector(client).verifyWebhook({
