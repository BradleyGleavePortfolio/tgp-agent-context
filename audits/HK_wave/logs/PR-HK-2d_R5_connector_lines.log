   251	  /**
   252	   * Pull Garmin history since `since` (clamped to {@link DEFAULT_SINCE_DAYS}).
   253	   * Pages each of the five summary collections by ≤24h windows (Garmin's
   254	   * per-request span cap), never exceeding {@link MAX_WINDOWS_PER_COLLECTION}.
   255	   * Records are wrapped as {@link RawRecord} carrying the subject + connection
   256	   * ids so the normalizer can build samples without re-resolving the
   257	   * connection.
   258	   */
   259	  async backfill(conn: WearableConnection, since: Date): Promise<RawRecord[]> {
   260	    const accessToken = await this.resolveAccessToken(conn);
--- connector 260-620 ---
   260	    const accessToken = await this.resolveAccessToken(conn);
   261	    const floor = new Date(
   262	      Date.now() - DEFAULT_SINCE_DAYS * 24 * 60 * 60 * 1000,
   263	    );
   264	    const start = since && since > floor ? since : floor;
   265	    const end = new Date();
   266	    const ctx = { userId: conn.user_id, connectionId: conn.id };
   267	
   268	    const startSec = Math.floor(start.getTime() / 1000);
   269	    const endSec = Math.floor(end.getTime() / 1000);
   270	
   271	    const results = await Promise.all(
   272	      GARMIN_SUMMARY_KINDS.map((kind) =>
   273	        this.pageCollection(kind, accessToken, startSec, endSec, ctx),
   274	      ),
   275	    );
   276	    return results.flat();
   277	  }
   278	
   279	  /**
   280	   * Resolve a usable PLAINTEXT access token for a backfill call:
   281	   *  - If `encrypted_access_token` is present and not expired, KMS-unwrap it.
   282	   *  - Else KMS-unwrap the refresh token and mint a fresh access token (NOT
   283	   *    persisted here — the connection layer persists via `refresh()`).
   284	   *  - Else re-consent is required → fail loud (#36).
   285	   * The plaintext token lives only on the stack; it is never logged (#1/#12).
   286	   */
   287	  private async resolveAccessToken(conn: WearableConnection): Promise<string> {
   288	    const expired =
   289	      conn.access_token_expires_at != null &&
   290	      conn.access_token_expires_at.getTime() <= Date.now();
   291	    if (conn.encrypted_access_token && !expired) {
   292	      return this.kms.decrypt(conn.encrypted_access_token);
   293	    }
   294	    if (conn.encrypted_refresh_token) {
   295	      const refreshToken = await this.kms.decrypt(conn.encrypted_refresh_token);
   296	      const rotated = await this.refreshAccessToken(refreshToken);
   297	      if (!rotated.accessToken) {
   298	        throw new Error('garmin.backfill: refresh returned no access token');
   299	      }
   300	      return rotated.accessToken;
   301	    }
   302	    throw new Error(
   303	      'garmin.backfill: connection has no access or refresh token (re-consent required)',
   304	    );
   305	  }
   306	
   307	  /**
   308	   * Page one Garmin summary collection across the [startSec, endSec] range in
   309	   * ≤24h windows. Each window is a single Garmin summary request; the records
   310	   * are wrapped as {@link RawRecord} with the kind discriminator + ctx threaded
   311	   * onto the payload. Bounded by {@link MAX_WINDOWS_PER_COLLECTION}.
   312	   */
   313	  private async pageCollection(
   314	    kind: GarminSummaryKind,
   315	    accessToken: string,
   316	    startSec: number,
   317	    endSec: number,
   318	    ctx: { userId: string; connectionId: string },
   319	  ): Promise<RawRecord[]> {
   320	    const out: RawRecord[] = [];
   321	    let windowStart = startSec;
   322	    let windows = 0;
   323	
   324	    while (windowStart < endSec && windows < MAX_WINDOWS_PER_COLLECTION) {
   325	      const windowEnd = Math.min(windowStart + WINDOW_SECONDS, endSec);
   326	      const params = new URLSearchParams({
   327	        uploadStartTimeInSeconds: String(windowStart),
   328	        uploadEndTimeInSeconds: String(windowEnd),
   329	      });
   330	      const res = await this.http.request(
   331	        `${SUMMARY_ENDPOINT[kind]}?${params.toString()}`,
   332	        {
   333	          method: 'GET',
   334	          headers: { Authorization: `Bearer ${accessToken}` },
   335	          label: `garmin.backfill.${kind}`,
   336	        },
   337	      );
   338	      const json = (await res.json()) as unknown;
   339	      const records = Array.isArray(json) ? (json as GarminSummary[]) : [];
   340	      for (const rec of records) {
   341	        out.push(this.wrapRecord(kind, rec, ctx));
   342	      }
   343	      windowStart = windowEnd;
   344	      windows += 1;
   345	    }
   346	    return out;
   347	  }
