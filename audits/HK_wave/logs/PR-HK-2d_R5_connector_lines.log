   141	  /**
   142	   * Build the Garmin OAuth2 authorization URL. `state` is the server-minted
   143	   * CSRF/PKCE state (PR-HK-1 owns generation/validation). Scopes are
   144	   * space-delimited.
   145	   */
   146	  buildAuthUrl(_userId: string, state: string): string | null {
   147	    const params = new URLSearchParams({
   148	      response_type: 'code',
   149	      client_id: this.clientId,
   150	      redirect_uri: this.redirectUri,
   151	      scope: GARMIN_SCOPES.join(' '),
   152	      state,
   153	    });
   154	    return `${GARMIN_AUTH_URL}?${params.toString()}`;
   155	  }
   156	
   157	  /** Exchange an OAuth authorization code for a {@link TokenSet}. */
   158	  async exchangeCode(code: string): Promise<TokenSet> {
   159	    const body = new URLSearchParams({
   160	      grant_type: 'authorization_code',
   161	      code,
   162	      client_id: this.clientId,
   163	      client_secret: this.clientSecret,
   164	      redirect_uri: this.redirectUri,
   165	    });
   166	    const tokens = await this.tokenRequest(body, 'garmin.exchangeCode');
   167	    return this.encryptTokenSet(tokens);
   168	  }
   169	
   170	  /**
   171	   * Refresh an expiring access token using the connection's KMS-wrapped
   172	   * refresh token. Garmin rotates refresh tokens on the OAuth2 flow, so the
   173	   * response's new refresh token is re-wrapped and returned for the connection
   174	   * layer to persist (the old one is invalidated). A 401 from Garmin surfaces
   175	   * as a thrown {@link ProviderHttpError} so the connection layer flips
   176	   * status='expired' (re-consent required) — never a silent success (#36).
   177	   */
   178	  async refresh(conn: WearableConnection): Promise<TokenSet> {
   179	    if (!conn.encrypted_refresh_token) {
   180	      throw new Error(
   181	        'garmin.refresh: connection has no refresh token (re-consent required)',
   182	      );
   183	    }
   184	    const refreshToken = await this.kms.decrypt(conn.encrypted_refresh_token);
   185	    const rotated = await this.refreshAccessToken(refreshToken);
   186	    return this.encryptTokenSet(rotated);
   187	  }
   188	
   189	  /**
   190	   * Low-level refresh by raw (plaintext) refresh token (also used by
   191	   * {@link backfill} when the cached access token is stale/absent). The
   192	   * returned {@link TokenSet.refreshToken} is the NEW PLAINTEXT token —
   193	   * callers that persist it MUST KMS-wrap it first (see {@link refresh}).
   194	   */
   195	  async refreshAccessToken(refreshToken: string): Promise<TokenSet> {
   196	    const body = new URLSearchParams({
   197	      grant_type: 'refresh_token',
   198	      refresh_token: refreshToken,
   199	      client_id: this.clientId,
   200	      client_secret: this.clientSecret,
   201	    });
   202	    return this.tokenRequest(body, 'garmin.refresh');
   203	  }
   204	
   205	  /**
   206	   * KMS-wrap the token-bearing fields of a {@link TokenSet} so the returned
   207	   * shape can be persisted directly into the connection's `encrypted_*`
   208	   * columns. Mirrors the WHOOP connector contract.
   209	   */
   210	  private async encryptTokenSet(tokens: TokenSet): Promise<TokenSet> {
   211	    return {
   212	      ...tokens,
   213	      refreshToken: await this.kms.encrypt(tokens.refreshToken),
   214	      accessToken:
   215	        tokens.accessToken != null
   216	          ? await this.kms.encrypt(tokens.accessToken)
   217	          : tokens.accessToken,
   218	    };
   219	  }
   220	
   221	  /** Shared OAuth token endpoint call → {@link TokenSet}. */
   222	  private async tokenRequest(
   223	    body: URLSearchParams,
   224	    label: string,
   225	  ): Promise<TokenSet> {
   226	    const res = await this.http.request(GARMIN_TOKEN_URL, {
   227	      method: 'POST',
   228	      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
   229	      body: body.toString(),
   230	      label,
   231	    });
   232	    const json = (await res.json()) as GarminTokenResponse;
   233	    if (!json.refresh_token) {
   234	      // A Garmin OAuth2 token response MUST yield a refresh token; its absence
   235	      // is a config error (wrong client / missing scope) — fail loud (#36).
   236	      throw new Error(`${label}: token response missing refresh_token`);
   237	    }
   238	    return {
   239	      refreshToken: json.refresh_token,
   240	      accessToken: json.access_token,
   241	      accessTokenExpiresAt: json.expires_in
   242	        ? new Date(Date.now() + json.expires_in * 1000)
   243	        : undefined,
   244	      scopes: json.scope ? json.scope.split(' ').filter(Boolean) : undefined,
   245	      externalAccountId: json.user_id != null ? String(json.user_id) : undefined,
   246	    };
   247	  }
