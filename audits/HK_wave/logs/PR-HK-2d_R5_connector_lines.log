   374	  // ── Webhook (partner-signed push) ──────────────────────────────────────
   375	
   376	  /**
   377	   * Verify a Garmin push. Garmin Health push has NO per-event HMAC, so the
   378	   * partner-signed contract is a static push token the receiver checks
   379	   * constant-time. We require `GARMIN_PUSH_TOKEN` to be configured and the
   380	   * inbound `X-Garmin-Push-Token` header to match it. Missing config → FAIL
   381	   * CLOSED (return false) so a misconfigured receiver never trusts a push
   382	   * (#36 fail-loud). A missing/mismatched header → false (controller → 401).
   383	   */
   384	  verifyWebhook(req: RawWebhookRequest): boolean {
   385	    const expected = this.pushToken;
   386	    if (!expected) {
   387	      this.logger.error(
   388	        'garmin.verifyWebhook: no GARMIN_PUSH_TOKEN configured — failing closed',
   389	      );
   390	      return false;
   391	    }
   392	    const provided = headerValue(req.headers, GARMIN_PUSH_TOKEN_HEADER);
   393	    if (!provided) {
   394	      return false;
   395	    }
   396	    const expectedBuf = Buffer.from(expected, 'utf8');
   397	    const providedBuf = Buffer.from(provided, 'utf8');
   398	    if (expectedBuf.length !== providedBuf.length) {
   399	      return false;
   400	    }
   401	    return timingSafeEqual(expectedBuf, providedBuf);
   402	  }
   403	
   404	  /**
   405	   * Parse a (already-token-verified) Garmin push into provider events. Garmin
   406	   * pushes the actual summary payload keyed by collection; we Zod-validate the
   407	   * envelope (`.strict()`), then emit ONE {@link ProviderEvent} per summary
   408	   * record. The `providerEventId` is `garmin:<kind>:<summaryId>` (namespaced
   409	   * so two collections sharing a summaryId never collide on the dedup PK), the
   410	   * `type` is the kind, and each event carries the single wrapped
   411	   * {@link RawRecord} — ready to normalize without a follow-up fetch.
   412	   *
   413	   * Returns `[]` on malformed JSON or a schema-rejected envelope (the
   414	   * controller maps an empty parse on a verified-but-malformed body to 400).
   415	   */
   416	  parseWebhook(req: RawWebhookRequest): ProviderEvent[] {
   417	    let envelope: GarminWebhookEnvelope;
   418	    try {
   419	      const json: unknown = JSON.parse(req.rawBody.toString('utf8'));
   420	      envelope = GarminWebhookEnvelopeSchema.parse(json);
   421	    } catch {
   422	      return [];
   423	    }
   424	    const events: ProviderEvent[] = [];
   425	    for (const kind of GARMIN_SUMMARY_KINDS) {
   426	      const records = envelope[kind];
   427	      if (!records) continue;
   428	      for (const rec of records) {
   429	        const summary = rec as unknown as GarminSummary;
   430	        const payload: GarminRawPayload = { kind, data: summary };
   431	        events.push({
   432	          providerEventId: `garmin:${kind}:${summary.summaryId}`,
   433	          type: kind,
   434	          records: [
   435	            {
   436	              id: summary.summaryId,
   437	              provider: this.provider,
   438	              payload,
   439	            },
   440	          ],
   441	        });
   442	      }
   443	    }
   444	    return events;
   445	  }
   446	}
   447	
   448	/** Read a header case-insensitively from a lower-cased map (first value). */
   449	function headerValue(
   450	  headers: Record<string, string | string[] | undefined>,
   451	  name: string,
   452	): string | undefined {
   453	  const v = headers[name] ?? headers[name.toLowerCase()];
   454	  if (Array.isArray(v)) return v[0];
   455	  return v;
   456	}
   457	
   458	/**
   459	 * Test/utility helper: derive the constant-time push-token comparison a Garmin
   460	 * receiver expects. Kept next to the verifier so the contract lives in one
   461	 * place; not exported from the module index. (Garmin's token is opaque — this
   462	 * helper exists for symmetry with the other connectors' signing helpers and to
   463	 * keep the header-name contract close to the verifier.)
   464	 */
   465	export function garminPushTokenHeader(token: string): {
   466	  name: string;
   467	  value: string;
   468	} {
   469	  return { name: GARMIN_PUSH_TOKEN_HEADER, value: token };
   470	}
   471	
   472	/**
   473	 * Derive a NON-reversible, event-scoped correlation id from a Garmin user id
   474	 * for logs (no PII in logs — Wave-2 audit pattern #3). SHA-256 of a salted
   475	 * `garmin:<userId>:<salt>` truncated to 16 hex chars. Salt comes from
   476	 * `GARMIN_WEBHOOK_SALT` (falls back to the push token / client secret).
   477	 */
   478	export function hashGarminUserId(userId: string): string {
   479	  const salt =
   480	    process.env.GARMIN_WEBHOOK_SALT ??
   481	    process.env.GARMIN_PUSH_TOKEN ??
   482	    process.env.GARMIN_CLIENT_SECRET ??
   483	    '';
   484	  return createHash('sha256')
   485	    .update(`garmin:${userId}:${salt}`)
   486	    .digest('hex')
   487	    .slice(0, 16);
   488	}
   489	
   490	/**
   491	 * A structured, log-safe descriptor of a failure on the Garmin ingest path.
   492	 * NEVER carries raw provider PII (Garmin `userId`), OAuth/user-access tokens,
   493	 * bearer fragments, or provider payload values — only an error class name and
   494	 * a scrubbed, length-capped message. Persisted to `last_error` and emitted in
   495	 * the `ingest_failure` log (Wave-2 audit pattern #3, PII/token redaction).
   496	 */
   497	export interface RedactedGarminError {
   498	  /** Stable machine code for dashboards/alerting (e.g. `GARMIN_INGEST_FAILED`). */
   499	  error_code: string;
   500	  /** The error's constructor name (e.g. `PrismaClientKnownRequestError`). */
   501	  error_class: string;
   502	  /** Scrubbed, length-capped message safe for logs and DB. */
   503	  redacted_message: string;
   504	}
   505	
   506	/**
   507	 * Patterns for token/secret-like fragments that must never reach logs or the
   508	 * `last_error` column. Order matters: the most specific (labelled) patterns run
   509	 * first so their values are masked before the generic long-token sweep.
   510	 */
   511	const GARMIN_SECRET_PATTERNS: ReadonlyArray<RegExp> = [
   512	  // `Bearer <token>` / `bearer=<token>` style fragments.
   513	  /\b[Bb]earer[\s=:]+[A-Za-z0-9._-]+/g,
   514	  // Labelled token/secret/key/password fields (json or kv form).
   515	  /\b(?:user[_-]?access[_-]?token|access[_-]?token|refresh[_-]?token|token|secret|password|api[_-]?key|authorization)\b["']?\s*[:=]\s*["']?[A-Za-z0-9._-]+/gi,
   516	  // Generic long opaque tokens (>= 20 chars of token alphabet).
   517	  /\b[A-Za-z0-9._-]{20,}\b/g,
   518	];
   519	
   520	/**
   521	 * Build a {@link RedactedGarminError} from a thrown value and the in-scope
   522	 * Garmin `userId`. Removes the literal user id, masks token/secret-like
   523	 * fragments, collapses whitespace, and caps length. Returns a fully-populated
   524	 * descriptor for every input (including non-`Error` throws) — never throws,
   525	 * never returns the raw message.
   526	 */
   527	export function redactGarminError(
   528	  err: unknown,
   529	  userId: string | undefined,
   530	  errorCode = 'GARMIN_INGEST_FAILED',
   531	): RedactedGarminError {
   532	  const error_class =
   533	    err instanceof Error && typeof err.constructor?.name === 'string'
   534	      ? err.constructor.name
   535	      : typeof err;
   536	
   537	  const rawMessage =
   538	    err instanceof Error
   539	      ? err.message
   540	      : typeof err === 'string'
   541	        ? err
   542	        : (() => {
   543	            try {
   544	              return JSON.stringify(err);
   545	            } catch {
   546	              return String(err);
   547	            }
   548	          })();
   549	
   550	  let scrubbed = typeof rawMessage === 'string' ? rawMessage : String(rawMessage);
   551	
   552	  // 1) Remove every occurrence of the literal Garmin user id (PII).
   553	  if (userId && userId.length > 0) {
   554	    scrubbed = scrubbed.split(userId).join('[redacted-user]');
   555	  }
   556	  // 2) Mask token/secret-like fragments.
   557	  for (const pattern of GARMIN_SECRET_PATTERNS) {
   558	    scrubbed = scrubbed.replace(pattern, '[redacted]');
   559	  }
   560	  // 3) Collapse whitespace and cap length.
   561	  scrubbed = scrubbed.replace(/\s+/g, ' ').trim().slice(0, 500);
   562	  if (scrubbed.length === 0) {
   563	    scrubbed = 'unknown';
   564	  }
   565	
   566	  return { error_code: errorCode, error_class, redacted_message: scrubbed };
   567	}
--- types 1-320 ---
     1	/**
     2	 * PR-HK-2.d — Garmin Health API provider-native types.
     3	 *
     4	 * These describe the *exact* shapes the connector receives from the Garmin
     5	 * Health API push ("ping/push") notifications and backfill responses. They
     6	 * are scoped to the fields the normalizer maps (AGENT_2_CODING_PLAN §3.1)
     7	 * plus the structural fields needed for paging, dedup, idempotency, and
     8	 * webhook handling — nothing speculative (50-Failures #42).
     9	 *
    10	 * Garmin distinctives baked in here:
    11	 *  - Auth is the Garmin **partner** OAuth model. The legacy Health API used
    12	 *    OAuth1.0a; the modern Health API uses OAuth2 (PKCE). The push-notification
    13	 *    delivery is a Garmin-signed partner callback ("partner_signed") — Garmin
    14	 *    POSTs the *actual summary payload* (NOT a lean reference like WHOOP) to a
    15	 *    pre-registered HTTPS callback URL. The callback URL is registered with a
    16	 *    partner-configured push verification token; there is NO per-event HMAC
    17	 *    signature header in the Garmin Health push spec, so the controller defends
    18	 *    the POST fail-closed via a configured push token + optional IP allow-list
    19	 *    (the Strava-style model, since both lack per-event HMAC).
    20	 *  - Timestamps are **epoch seconds** (`startTimeInSeconds`,
    21	 *    `startTimeOffsetInSeconds`, `calendarDate`). The normalizer converts to UTC
    22	 *    `Date`s and threads the offset into `sourceTz` so DST/travel cannot
    23	 *    off-by-one the day bucket.
    24	 *  - Durations are **seconds** (`durationInSeconds`, `deepSleepDurationInSeconds`,
    25	 *    …); the normalizer converts to minutes. Distance is **meters**.
    26	 *  - Each summary carries a `summaryId` (provider-native record id, dedup +
    27	 *    event-id segment) and a `userAccessToken` / `userId` (the Garmin user
    28	 *    access token / Garmin user id — PII, never logged).
    29	 *
    30	 * Source (verified May 2026): Garmin Health API — Summary Push Service,
    31	 *   https://developer.garmin.com/gc-developer-program/health-api/  (dailies,
    32	 *   sleeps, hrv, activities, bodyComps summaries; epoch-second timestamps;
    33	 *   partner push callbacks).
    34	 */
    35	
    36	import { z } from 'zod';
    37	
    38	/** The Garmin summary collections this connector ingests (§3.1 Garmin row). */
    39	export type GarminSummaryKind =
    40	  | 'dailies'
    41	  | 'sleeps'
    42	  | 'hrv'
    43	  | 'activities'
    44	  | 'bodyComps';
    45	
    46	/** All summary kinds, drives the Zod webhook envelope keys. */
    47	export const GARMIN_SUMMARY_KINDS = [
    48	  'dailies',
    49	  'sleeps',
    50	  'hrv',
    51	  'activities',
    52	  'bodyComps',
    53	] as const satisfies readonly GarminSummaryKind[];
    54	
    55	/**
    56	 * Fields common to every Garmin summary record. `summaryId` is the
    57	 * provider-native record id (dedup + idempotency segment); `userId` is the
    58	 * Garmin user id (the connection's `external_account_id`); `userAccessToken`
    59	 * is the OAuth user access token Garmin echoes on the push (PII — never
    60	 * logged). `startTimeInSeconds` + `startTimeOffsetInSeconds` give the local
    61	 * window start; `durationInSeconds` the span.
    62	 */
    63	export interface GarminSummaryBase {
    64	  /** Provider-native summary id (dedup + event-id segment). */
    65	  summaryId: string;
    66	  /** Garmin user id — the connection external_account_id (PII). */
    67	  userId: string;
    68	  /** Garmin OAuth user access token echoed on the push (PII — never logged). */
    69	  userAccessToken?: string;
    70	  /** Window start, epoch SECONDS (UTC). */
    71	  startTimeInSeconds?: number;
    72	  /** Local-time offset from UTC, seconds (threaded into sourceTz). */
    73	  startTimeOffsetInSeconds?: number;
    74	  /** Window duration, seconds. */
    75	  durationInSeconds?: number;
    76	  /** Calendar date (YYYY-MM-DD) for day-bucketed summaries (dailies). */
    77	  calendarDate?: string;
    78	}
    79	
    80	/**
    81	 * Garmin Daily Summary (`dailies`). H&F. Maps `steps` → STEPS and
    82	 * `activeKilocalories` → ACTIVE_ENERGY_KCAL.
    83	 */
    84	export interface GarminDaily extends GarminSummaryBase {
    85	  /** Step count for the day → STEPS. */
    86	  steps?: number;
    87	  /** Active calories (kcal) for the day → ACTIVE_ENERGY_KCAL. */
    88	  activeKilocalories?: number;
    89	}
    90	
    91	/**
    92	 * Garmin Sleep Summary (`sleeps`). S&R. Stage durations are SECONDS; total is
    93	 * the sum of the stage durations Garmin reports. `bodyBattery*` feeds
    94	 * BODY_BATTERY.
    95	 */
    96	export interface GarminSleep extends GarminSummaryBase {
    97	  /** Deep sleep, seconds → SLEEP_DEEP_MIN. */
    98	  deepSleepDurationInSeconds?: number;
    99	  /** Light sleep, seconds → SLEEP_LIGHT_MIN. */
   100	  lightSleepDurationInSeconds?: number;
   101	  /** REM sleep, seconds → SLEEP_REM_MIN. */
   102	  remSleepInSeconds?: number;
   103	  /** Awake time, seconds → SLEEP_AWAKE_MIN. */
   104	  awakeDurationInSeconds?: number;
   105	  /**
   106	   * Validation flag. Garmin marks auto-detected vs manually-confirmed sleep;
   107	   * only `ENHANCED_CONFIRMED` / `ENHANCED_TENTATIVE` carry stage data worth
   108	   * ingesting. `MANUAL` / unset is skipped by the normalizer.
   109	   */
   110	  validation?: string;
   111	  /**
   112	   * Overnight Body Battery change. Garmin reports the dynamic min/max across
   113	   * the sleep; we surface the most-recent value (`bodyBatteryChange` when
   114	   * present, else `endingBodyBattery`) → BODY_BATTERY.
   115	   */
   116	  endingBodyBattery?: number;
   117	  bodyBatteryChange?: number;
   118	}
   119	
   120	/**
   121	 * Garmin HRV Summary (`hrv`). S&R. `lastNightAvg` is the overnight average
   122	 * HRV in **milliseconds** → HRV_MS.
   123	 */
   124	export interface GarminHrv extends GarminSummaryBase {
   125	  /** Overnight average HRV (ms) → HRV_MS. */
   126	  lastNightAvg?: number;
   127	  /** Highest 5-min HRV value overnight (ms); not ingested, kept for context. */
   128	  lastNight5MinHigh?: number;
   129	}
   130	
   131	/**
   132	 * Garmin Activity Summary (`activities`). H&F. `durationInSeconds` →
   133	 * WORKOUT_DURATION_MIN, `distanceInMeters` → WORKOUT_DISTANCE_M, and Garmin's
   134	 * `activityTrainingLoad` → TRAINING_LOAD.
   135	 */
   136	export interface GarminActivity extends GarminSummaryBase {
   137	  /** Activity type label (e.g. "RUNNING"); kept for context, not ingested. */
   138	  activityType?: string;
   139	  /** Distance in meters → WORKOUT_DISTANCE_M. */
   140	  distanceInMeters?: number;
   141	  /** Garmin training-load score for the activity → TRAINING_LOAD. */
   142	  activityTrainingLoad?: number;
   143	}
   144	
   145	/**
   146	 * Garmin Body Composition Summary (`bodyComps`). H&F. `weightInGrams` →
   147	 * BODY_WEIGHT_KG (converted), `bodyFatInPercent` → BODY_FAT_PCT.
   148	 */
   149	export interface GarminBodyComp extends GarminSummaryBase {
   150	  /** Body mass in GRAMS → BODY_WEIGHT_KG (÷ 1000). */
   151	  weightInGrams?: number;
   152	  /** Body fat percentage → BODY_FAT_PCT. */
   153	  bodyFatInPercent?: number;
   154	}
   155	
   156	/** Union of all Garmin summary record shapes. */
   157	export type GarminSummary =
   158	  | GarminDaily
   159	  | GarminSleep
   160	  | GarminHrv
   161	  | GarminActivity
   162	  | GarminBodyComp;
   163	
   164	/**
   165	 * The envelope the connector wraps every backfilled/pushed record in before
   166	 * handing it to `normalize()`. `kind` selects the mapper; `data` is the
   167	 * untouched Garmin record. `userId`/`connectionId` are the SUBJECT-client +
   168	 * connection ids (threaded by the connector / webhook controller so
   169	 * `normalize(raw)` can build samples without re-resolving the connection).
   170	 */
   171	export interface GarminRawPayload {
   172	  kind: GarminSummaryKind;
   173	  data: GarminSummary;
   174	  /** Subject-client User.id (threaded by connector/controller). */
   175	  userId?: string;
   176	  /** Connection id (threaded by connector/controller). */
   177	  connectionId?: string;
   178	}
   179	
   180	/**
   181	 * Garmin OAuth token endpoint response (Health API OAuth2/PKCE flow). The
   182	 * connector also supports the legacy OAuth1.0a partner flow, but the canonical
   183	 * {@link TokenSet} mapping reads the OAuth2 fields.
   184	 */
   185	export interface GarminTokenResponse {
   186	  access_token?: string;
   187	  refresh_token?: string;
   188	  expires_in?: number;
   189	  scope?: string;
   190	  /** Garmin user id (echoed on some token responses). */
   191	  user_id?: string;
   192	}
   193	
   194	// ── Webhook (push) validation ───────────────────────────────────────────────
   195	
   196	/**
   197	 * Garmin push summary records arrive as arrays keyed by collection. We
   198	 * validate each record with a permissive-but-strict-on-known-keys schema:
   199	 * the record MUST carry a `summaryId` + `userId`; numeric Garmin fields are
   200	 * optional numbers. `.passthrough()` is deliberately NOT used at the RECORD
   201	 * level — Garmin evolves summary fields, but the ENVELOPE is `.strict()` so a
   202	 * drifted top-level key (a forged extra collection) is rejected.
   203	 *
   204	 * NOTE on `.strict()` (Wave-2 audit pattern #4): the foundational guard is on
   205	 * the ENVELOPE — only the five known summary collections may appear. Record
   206	 * objects allow unknown keys (Garmin adds fields over time) but unknown
   207	 * TOP-LEVEL collections are rejected so a malformed/forged push cannot smuggle
   208	 * an unexpected collection past validation.
   209	 */
   210	const GarminSummaryRecordSchema = z
   211	  .object({
   212	    summaryId: z.string().min(1),
   213	    userId: z.string().min(1),
   214	    userAccessToken: z.string().optional(),
   215	    startTimeInSeconds: z.number().int().optional(),
   216	    startTimeOffsetInSeconds: z.number().int().optional(),
   217	    durationInSeconds: z.number().int().nonnegative().optional(),
   218	    calendarDate: z.string().optional(),
   219	  })
   220	  .passthrough();
   221	
   222	/**
   223	 * The Garmin push envelope. Garmin POSTs `{ "<kind>": [ {…record…}, … ] }`,
   224	 * possibly with several collections in one push. EVERY top-level key must be
   225	 * one of the five known summary kinds (`.strict()` rejects unknown keys —
   226	 * audit pattern #4) and each maps to an array of summary records.
   227	 */
   228	export const GarminWebhookEnvelopeSchema = z
   229	  .object({
   230	    dailies: z.array(GarminSummaryRecordSchema).optional(),
   231	    sleeps: z.array(GarminSummaryRecordSchema).optional(),
   232	    hrv: z.array(GarminSummaryRecordSchema).optional(),
   233	    activities: z.array(GarminSummaryRecordSchema).optional(),
   234	    bodyComps: z.array(GarminSummaryRecordSchema).optional(),
   235	  })
   236	  .strict();
   237	
   238	/** The validated push envelope. */
   239	export type GarminWebhookEnvelope = z.infer<typeof GarminWebhookEnvelopeSchema>;
   240	
   241	/**
   242	 * Garmin de-registration ("user permission revoked") notification. Garmin
   243	 * delivers deregistrations to a separate callback as
   244	 * `{ "deregistrations": [ { userId, userAccessToken } ] }`. We model it so the
   245	 * controller can flip the connection to `status='disconnected'`.
   246	 */
   247	export const GarminDeregistrationSchema = z
   248	  .object({
   249	    deregistrations: z
   250	      .array(
   251	        z
   252	          .object({
   253	            userId: z.string().min(1),
   254	            userAccessToken: z.string().optional(),
   255	          })
   256	          .passthrough(),
   257	      )
   258	      .min(1),
   259	  })
   260	  .strict();
   261	
   262	export type GarminDeregistration = z.infer<typeof GarminDeregistrationSchema>;
   263	
   264	/**
   265	 * Lower-cased Garmin push header carrying the partner-configured verification
   266	 * token. Garmin allows partners to set a static header on push delivery so the
   267	 * receiver can fail-closed reject pushes that do not carry the expected token
   268	 * (the connector's primary POST defense, since Garmin Health push has no
   269	 * per-event HMAC).
   270	 */
   271	export const GARMIN_PUSH_TOKEN_HEADER = 'x-garmin-push-token';
