    82	  'sleeps',
    83	  'hrv',
    84	  'bodyComps',
    85	] as const;
    86	
    87	/** Default backfill window (days). Garmin allows up to 90 on connect. */
    88	const DEFAULT_SINCE_DAYS = 90;
    89	/** Garmin caps a single summary request to a 24h span; we page by day. */
    90	const WINDOW_SECONDS = 24 * 60 * 60;
    91	/** Hard ceiling on windows per collection — defence against a runaway range. */
    92	const MAX_WINDOWS_PER_COLLECTION = 100;
