   102	  hrv: `${GARMIN_WELLNESS_BASE}/hrv`,
   103	  activities: `${GARMIN_WELLNESS_BASE}/activities`,
   104	  bodyComps: `${GARMIN_WELLNESS_BASE}/bodyComps`,
   105	};
