   349	  /** Wrap a Garmin summary record into a {@link RawRecord} with ctx + kind. */
   350	  private wrapRecord(
   351	    kind: GarminSummaryKind,
   352	    rec: GarminSummary,
   353	    ctx: { userId: string; connectionId: string },
   354	  ): RawRecord {
   355	    const payload: GarminRawPayload = {
   356	      kind,
   357	      data: rec,
   358	      userId: ctx.userId,
   359	      connectionId: ctx.connectionId,
   360	    };
   361	    return {
   362	      id: rec.summaryId,
   363	      provider: this.provider,
   364	      payload,
   365	    };
   366	  }
